{
  "servers": {
    "k8s": {
      "transport": "stdio",
      "command": ".venv/bin/python",
      "args": ["examples/mcp_servers/k8s/server.py"],
      "timeout_seconds": 30,
      "read_only": true,
      "tool_exposure": "allowlist",
      "metadata": {
        "category": "kubernetes",
        "execution_scope": "remote",
        "credential_sensitive": true,
        "redaction_required": true
      },
      "tools": {
        "kubectl_get": {},
        "kubectl_describe": {},
        "cluster_events": {}
      }
    }
  }
}
